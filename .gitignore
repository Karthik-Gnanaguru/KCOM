MANIFEST

# ── Virtual environments ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── PyInstaller build output ────────────────────────────────────────────────────
# Build SCRIPTS live in build/ and are committed.
# Build ARTIFACTS (binaries) go into dist/ and are NOT committed — they are
# attached to GitHub Releases instead.
dist/
*.spec.bak

