.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
tests/coverage_html/
tests/report.html
.pytest_cache/
.tox/

# ── KCom runtime files ──────────────────────────────────────────────────────────
kcom-session.txt
*.klog
*.bak

# ── Draft / development-only files ─────────────────────────────────────────────
draft/

# ── Internal project docs (local reference only, not for repo) ───────────────
